# Flask
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-me-in-production

# Database (default: SQLite in instance folder)
# DATABASE_URI=sqlite:///instance/wos.db

# JWT (API auth)
JWT_SECRET_KEY=change-me-in-production-jwt
JWT_ACCESS_TOKEN_EXPIRES=86400

# Optional: HTTPS session cookies
# PREFER_HTTPS=0

# Optional: rate limit (e.g. 100 per minute)
# RATELIMIT_DEFAULT=100 per minute
